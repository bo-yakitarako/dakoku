{
  "name": "dakoku-server",
  "version": "2.0.0",
  "description": "あばー",
  "main": "index.js",
  "author": "bo-yakitarako",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "tsup src/index.ts --format cjs --platform node --minify --out-dir dist",
    "start": "pnpm build && node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "tsx src/db/reset.ts && drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@libsql/client": "^0.17.2",
    "better-auth": "^1.5.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.9",
    "jsonwebtoken": "^9.0.3",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
